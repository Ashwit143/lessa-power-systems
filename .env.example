# =============================================================================
# Environment Variables — Leesa Power Systems
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# WhatsApp
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://leesapowersystems.com

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_LEAD_LOGGING=true

# -----------------------------------------------------------------------------
# Business Information
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BUSINESS_NAME=Leesa Power Systems
NEXT_PUBLIC_BUSINESS_EMAIL=leesapowersystems@gmail.com

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@leesapowersystems.com